# OS
.DS_Store
Thumbs.db

# App data — personal & generated
data/personal.db
data/screenshots/
data/game/_raw/*.json
data/game/heroes.json
data/game/traits.json
data/game/gear_stats.json
data/game/arcana.json
data/game/forge_rules.json
