# OCR debug-image dumps — only created when BLOOD_HUNT_OCR_DEBUG=1.
data/debug/

# Per-machine OCR template images — captured from the user's own UI/resolution.
data/game/_assets/tier_badges/*.png
data/game/_assets/slot_icons/*.png

# Don't ignore the seed/sample fixtures or the _assets README
!data/game/*.seed.json
!apps/api/tests/fixtures/raw_exports/*.sample.json
!data/game/_assets/README.md

# Editor
.vscode/
.idea/
